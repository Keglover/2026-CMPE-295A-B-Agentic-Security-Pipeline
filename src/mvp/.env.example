# Agentic Security Pipeline — Environment Variables
# Copy this file:  cp .env.example .env
# Then fill in your API key. Never commit .env itself.

# --- LLM Provider ---
# OpenAI (default):
OPENAI_API_KEY=sk-your-key-here
AGENT_MODEL=gpt-4o-mini

# For Qwen via Together AI, uncomment and set your key:
# OPENAI_API_KEY=your-together-ai-key
# OPENAI_BASE_URL=https://api.together.xyz/v1
# AGENT_MODEL=Qwen/Qwen2.5-72B-Instruct

# For Qwen via Ollama (local), uncomment:
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# AGENT_MODEL=qwen2.5:7b

# --- LLM-as-Judge (risk engine, ambiguous-band escalation) ---
# Toggle the judge layer (default: false). When true and 15 <= score < 60,
# the risk engine calls the judge to decide if input is manipulative.
LLM_JUDGE_ENABLED=false

# Judge backend selection:
#   - If OPENAI_API_KEY is set, the judge uses OpenAI (gpt-4o-mini by default).
#   - Otherwise it falls back to Ollama using the URL/key/model below.
#
# Local Ollama (no auth required):
OLLAMA_URL=http://localhost:11434
# OLLAMA_API_KEY=                       # leave blank for local
# OLLAMA_MODEL=llama3.1:8b
#
# Hosted Ollama (e.g. Ollama Cloud / Turbo) — uncomment and fill in:
# OLLAMA_URL=https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key-here
# OLLAMA_MODEL=llama3.1:8b

# --- Pipeline ---
PIPELINE_URL=http://localhost:8000/pipeline
AGENT_MAX_ITERATIONS=5

# --- Pipeline Server ---
REAL_TOOLS=false
AUDIT_LOG_PATH=audit_logs/audit.ndjson
